{
  "name": "fake-news-detector-students",
  "description": "Fast, simple, educational fake news check made specifically for students",
  "repository": "https://github.com/your-username/fake-news-detector",
  "logo": "https://cdn-icons-png.flaticon.com/512/2965/2965879.png",
  "keywords": [
    "fake-news",
    "misinformation",
    "education",
    "nlp",
    "students",
    "media-literacy"
  ],
  "website": "https://github.com/your-username/fake-news-detector",
  "success_url": "/",
  "scripts": {
    "postdeploy": "npm run migrate && npm run seed"
  },
  "env": {
    "NODE_ENV": {
      "description": "Node environment",
      "value": "production"
    },
    "PORT": {
      "description": "Port for the app",
      "value": "3000"
    },
    "GOOGLE_FACT_CHECK_API_KEY": {
      "description": "API key for Google Fact Check Tools",
      "required": true
    },
    "NEWS_API_KEY": {
      "description": "API key for NewsAPI or similar source checker",
      "required": false
    },
    "OPENAI_API_KEY": {
      "description": "API key for NLP/summarization",
      "required": true
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ],
  "stack": "heroku-24"
}
